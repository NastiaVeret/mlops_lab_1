# Скопіюйте в .env і підлаштуйте під свою систему.
# Linux: AIRFLOW_UID=$(id -u)
AIRFLOW_UID=50000

# Для DAG ml_pipeline_docker_operator — абсолютний шлях до репозиторію на хості (для bind mount у DockerOperator).
# Приклад macOS: ML_PROJECT_HOST_PATH=/Users/you/Desktop/mlops_lab_1
# ML_PROJECT_HOST_PATH=

# Опційно: власний Fernet-ключ (генерація: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# AIRFLOW_FERNET_KEY=
